// Diagram for ForProfitOrganization
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		Organization [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Organization</TD></TR></TABLE>> URL="../Organization" margin=0]
	}
	ForProfitOrganization [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ForProfitOrganization</TD></TR></TABLE>> URL="../ForProfitOrganization" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		BusinessEstablishment [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">BusinessEstablishment</TD></TR></TABLE>> URL="../BusinessEstablishment" margin=0]
		IndustryType [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">IndustryType</TD></TR></TABLE>> URL="../IndustryType" margin=0]
	}
	ForProfitOrganization -> Organization [arrowhead=onormal style=solid]
	ForProfitOrganization -> Invis [style=invis]
	Invis -> BusinessEstablishment [style=invis]
	BusinessEstablishment -> IndustryType [style=invis]
	IndustryType [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">IndustryType</TD></TR></TABLE>> URL="../IndustryType" margin=0]
	ForProfitOrganization -> IndustryType [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasIndustryType</TD></TR></TABLE>> arrowhead=normal style=solid]
	BusinessEstablishment [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">BusinessEstablishment</TD></TR></TABLE>> URL="../BusinessEstablishment" margin=0]
	ForProfitOrganization -> BusinessEstablishment [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasEstablishment</TD></TR></TABLE>> arrowhead=normal style=solid]
}
