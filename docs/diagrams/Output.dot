// Diagram for Output
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		cdm1_TerminalResourceState [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm1:TerminalResourceState</TD></TR></TABLE>> URL="https://w3id.org/citydata/part1/v1/TerminalResourceState" margin=0]
		CityServiceThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">CityServiceThing</TD></TR></TABLE>> URL="../CityServiceThing" margin=0]
	}
	Output [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Output</TD></TR><TR><TD ALIGN="LEFT">cdm1:hasDescription : xsd:string</TD></TR><TR><TD ALIGN="LEFT">cdm1:hasName : xsd:string [0..1]</TD></TR></TABLE>> URL="../Output" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		i72_Indicator [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">i72:Indicator</TD></TR></TABLE>> URL="https://w3id.org/citydata/21972/v1/Indicator" margin=0]
	}
	Output -> cdm1_TerminalResourceState [arrowhead=onormal style=solid]
	Output -> CityServiceThing [arrowhead=onormal style=solid]
	Output -> Invis [style=invis]
	Invis -> i72_Indicator [style=invis]
	i72_Indicator [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">i72:Indicator</TD></TR></TABLE>> URL="https://w3id.org/citydata/21972/v1/Indicator" margin=0]
	Output -> i72_Indicator [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">usedByIndicator</TD></TR></TABLE>> arrowhead=normal style=solid]
}
