// Diagram for Law
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		BylawThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">BylawThing</TD></TR></TABLE>> URL="../BylawThing" margin=0]
	}
	Law [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Law</TD></TR><TR><TD ALIGN="LEFT">abstract : xsd:string [0..1]</TD></TR><TR><TD ALIGN="LEFT">cdm1:hasName : xsd:string</TD></TR><TR><TD ALIGN="LEFT">dateInEffect : xsd:dateTime [0..1]</TD></TR><TR><TD ALIGN="LEFT">datePublished : xsd:dateTime [0..1]</TD></TR><TR><TD ALIGN="LEFT">expires : xsd:dateTime [0..1]</TD></TR><TR><TD ALIGN="LEFT">keywords : xsd:string</TD></TR><TR><TD ALIGN="LEFT">legislationDate : xsd:dateTime [0..1]</TD></TR><TR><TD ALIGN="LEFT">legislationIdentifier : xsd:string [0..1]</TD></TR></TABLE>> URL="../Law" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		Clause [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Clause</TD></TR></TABLE>> URL="../Clause" margin=0]
		Definition [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Definition</TD></TR></TABLE>> URL="../Definition" margin=0]
		JurisdictionalArea [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">JurisdictionalArea</TD></TR></TABLE>> URL="../JurisdictionalArea" margin=0]
		LegislationLegalForceCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">LegislationLegalForceCode</TD></TR></TABLE>> URL="../LegislationLegalForceCode" margin=0]
		Schedule [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Schedule</TD></TR></TABLE>> URL="../Schedule" margin=0]
	}
	Law -> BylawThing [arrowhead=onormal style=solid]
	Law -> Invis [style=invis]
	Invis -> Clause [style=invis]
	Clause -> Definition [style=invis]
	Definition -> JurisdictionalArea [style=invis]
	JurisdictionalArea -> LegislationLegalForceCode [style=invis]
	LegislationLegalForceCode -> Schedule [style=invis]
	Schedule [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Schedule</TD></TR></TABLE>> URL="../Schedule" margin=0]
	Law -> Schedule [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasSchedule</TD></TR></TABLE>> arrowhead=normal style=solid]
	Clause [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Clause</TD></TR></TABLE>> URL="../Clause" margin=0]
	Law -> Clause [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasClause</TD></TR></TABLE>> arrowhead=normal style=solid]
	Definition [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Definition</TD></TR></TABLE>> URL="../Definition" margin=0]
	Law -> Definition [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasDefinition</TD></TR></TABLE>> arrowhead=normal style=solid]
	JurisdictionalArea [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">JurisdictionalArea</TD></TR></TABLE>> URL="../JurisdictionalArea" margin=0]
	Law -> JurisdictionalArea [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">legislationJurisdiction</TD></TR><TR><TD ALIGN="CENTER">0..1</TD></TR></TABLE>> arrowhead=normal style=solid]
	LegislationLegalForceCode [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">LegislationLegalForceCode</TD></TR></TABLE>> URL="../LegislationLegalForceCode" margin=0]
	Law -> LegislationLegalForceCode [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">legislationLegalForce</TD></TR></TABLE>> arrowhead=normal style=solid]
	Law -> Clause [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasTransitionClause</TD></TR></TABLE>> arrowhead=normal style=solid]
	Law -> Clause [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasPenaltyClause</TD></TR></TABLE>> arrowhead=normal style=solid]
	Law -> Clause [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasSeveranceClause</TD></TR></TABLE>> arrowhead=normal style=solid]
	Law -> Clause [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasRepealClause</TD></TR></TABLE>> arrowhead=normal style=solid]
}
