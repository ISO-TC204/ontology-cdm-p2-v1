// Diagram for PersonName
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		Name [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Name</TD></TR></TABLE>> URL="../Name" margin=0]
		PersonThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PersonThing</TD></TR></TABLE>> URL="../PersonThing" margin=0]
	}
	PersonName [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PersonName</TD></TR><TR><TD ALIGN="LEFT">additionalName : xsd:string</TD></TR><TR><TD ALIGN="LEFT">familyName : xsd:string [0..1]</TD></TR><TR><TD ALIGN="LEFT">givenName : xsd:string</TD></TR></TABLE>> URL="../PersonName" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
	}
	PersonName -> Name [arrowhead=onormal style=solid]
	PersonName -> PersonThing [arrowhead=onormal style=solid]
}
