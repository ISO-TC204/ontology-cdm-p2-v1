@prefix : <https://w3id.org/citydata/part2/v1/> .
@prefix cdm2: <https://w3id.org/citydata/part2/v1/> .
@prefix cdm1: <https://w3id.org/citydata/part1/v1/> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix i72: <https://w3id.org/citydata/21972/v1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .

:InfrastructureSHACL
    rdf:type owl:Ontology ;
    dcterms:title "City Data Model Part 2 - Infrastructure Pattern - SHACL constraints" ;
    skos:definition "SHACL validation shapes for the Infrastructure Pattern pattern module." ;
    vann:preferredNamespaceUri "https://w3id.org/citydata/part2/v1/" ;
    vann:preferredNamespacePrefix "cdm2" ;
    owl:imports :InfrastructurePattern ;
    owl:imports :CoreSHACL .

:InfrastructureElementShape
    rdf:type sh:NodeShape ;
    sh:targetClass :InfrastructureElement ;
    sh:property [
        sh:path cdm1:hasLocation ;
        sh:class cdm1:Location
    ] ;
    sh:property [
        sh:path i72:hasValue ;
        sh:class cdm1:MonetaryValue
    ] ;
    sh:property [
        sh:path cdm1:hasProperPart ;
        sh:class :InfrastructureElement
    ] ;
    sh:property [
        sh:path cdm1:hasName ;
        sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path :hasAddress ;
        sh:class :Address
    ] ;
    sh:property [
        sh:path cdm1:hasDescription ;
        sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path cdm1:hasIdentifier ;
        sh:datatype xsd:string
    ] .
