@prefix : <https://w3id.org/citydata/part2/v1/> .
@prefix cdm2: <https://w3id.org/citydata/part2/v1/> .
@prefix cdm1: <https://w3id.org/citydata/part1/v1/> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix i72: <https://w3id.org/citydata/21972/v1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .

:CorePattern
    dcterms:title            "Information technology - City data model - Part 2: City level concepts - Core concepts" ;
    skos:definition          "This ontology specifies the city-level concepts that are used by all other patterns of the city-level portion of the city data model." ;
    vann:preferredNamespaceUri "https://w3id.org/citydata/part2/v1/" ;
    vann:preferredNamespacePrefix "cdm2" ;
    dcterms:creator          "Kenneth Vaughn" ;
    dcterms:creator          "Mark Fox" ;
    dcterms:creator          "Megan Katsumi" ;
    dcterms:bibliographicCitation "ISO/IEC 5087-2:2024" ;
    rdfs:seeAlso             <https://www.iso.org/standard/80742.html> ;
    dcterms:modified         "2026-02-12"^^xsd:date ;
    owl:versionInfo          "1.3.0" ;
    owl:versionIRI           <https://w3id.org/citydata/part2/v1/CorePattern/r3.0/> ;
    cc:license               "http://creativecommons.org/licenses/by/4.0/" ;
    owl:imports              cdm1:CorePattern ;
    rdf:type                 owl:Ontology .

:CityDataProperty
    rdf:type                 owl:DatatypeProperty ;
    rdfs:subPropertyOf       cdm1:CdmDataProperty ;
    skos:definition          "Added for organizational purposes, to identify data properties defined for city-level CDM ontology." .

:CityObjectProperty
    rdf:type                 owl:ObjectProperty ;
    rdfs:subPropertyOf       cdm1:CdmObjectProperty ;
    skos:definition          "Added for organizational purposes, to identify object properties defined for city-level CDM ontology." .

:CityThing
    rdf:type                 owl:Class ;
    skos:definition          "Added for organizational purposes, to identify classes defined for the city-level CDM ontology." ;
    rdfs:subClassOf          cdm1:CdmThing .
