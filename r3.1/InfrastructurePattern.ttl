@prefix : <https://w3id.org/citydata/part2/v1/> .
@prefix cdm2: <https://w3id.org/citydata/part2/v1/> .
@prefix cdm1: <https://w3id.org/citydata/part1/v1/> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix i72: <https://w3id.org/citydata/21972/v1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .

:InfrastructurePattern
    dcterms:title            "Information technology - City data model - Part 2: City level concepts - Infrastructure pattern" ;
    skos:definition          "This ontology specifies the city-level concepts for the infrastructure pattern of the city data model. The Infrastructure pattern defines the concepts needed to capture various types of city infrastructure, such as buildings and roads. The Infrastructure pattern reuses the Spatial Location pattern (from ISO 5087-1) in order to capture the location of these infrastructure elements." ;
    vann:preferredNamespaceUri "https://w3id.org/citydata/part2/v1/" ;
    vann:preferredNamespacePrefix "cdm2" ;
    dcterms:creator          "Kenneth Vaughn" ;
    dcterms:creator          "Mark Fox" ;
    dcterms:creator          "Megan Katsumi" ;
    dcterms:bibliographicCitation "ISO/IEC 5087-2:2024" ;
    rdfs:seeAlso             <https://www.iso.org/standard/80742.html> ;
    rdfs:comment             "The prior version of this ontology used a different ontology IRI. This update remains semantically consistent with the version adopted as ISO 5087-2:2024." ;
    owl:priorVersion         <https://standards.iso.org/iso-iec/5087/-2/ed-1/en/ontology/Infrastructure/> ;
    dcterms:modified         "2026-02-12"^^xsd:date ;
    owl:versionInfo          "1.3.0" ;
    owl:versionIRI           <https://w3id.org/citydata/part2/v1/InfrastructurePattern/r3.0/> ;
    cc:license               "http://creativecommons.org/licenses/by/4.0/" ;
    owl:imports              :ContactPattern ;
    rdf:type                 owl:Ontology .

:InfrastructureElement
    rdf:type                 owl:Class ;
    skos:definition          "An Infrastructure Element is a generic representation of a city structure of interest." ;
    rdfs:subClassOf          :InfrastructureThing ;
    rdfs:subClassOf [
        rdf:type                     owl:Restriction ;
        owl:onProperty               i72:hasValue ;
        owl:onClass                  cdm1:MonetaryValue
    ] ;
    rdfs:subClassOf [
        rdf:type                     owl:Restriction ;
        owl:onProperty               :hasAddress ;
        owl:onClass                  :Address
    ] ;
    rdfs:subClassOf [
        rdf:type                     owl:Restriction ;
        owl:onProperty               cdm1:hasIdentifier ;
        owl:onDataRange              xsd:string
    ] ;
    rdfs:subClassOf [
        rdf:type                     owl:Restriction ;
        owl:onProperty               cdm1:hasName ;
        owl:onDataRange              xsd:string
    ] ;
    rdfs:subClassOf [
        rdf:type                     owl:Restriction ;
        owl:onProperty               cdm1:hasLocation ;
        owl:onClass                  cdm1:Location
    ] ;
    rdfs:subClassOf [
        rdf:type                     owl:Restriction ;
        owl:onProperty               cdm1:hasProperPart ;
        owl:onClass                  :InfrastructureElement
    ] ;
    rdfs:subClassOf [
        rdf:type                     owl:Restriction ;
        owl:onProperty               cdm1:hasDescription ;
        owl:onDataRange              xsd:string
    ] .

:InfrastructureThing
    rdf:type                 owl:Class ;
    skos:definition          "Added for organizational purposes, to identify classes defined in the Infrastructure pattern." ;
    rdfs:subClassOf          :CityThing .
