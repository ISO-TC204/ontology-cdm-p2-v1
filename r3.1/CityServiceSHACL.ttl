@prefix : <https://w3id.org/citydata/part2/v1/> .
@prefix cdm2: <https://w3id.org/citydata/part2/v1/> .
@prefix cdm1: <https://w3id.org/citydata/part1/v1/> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix i72: <https://w3id.org/citydata/21972/v1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .

:CityServiceSHACL
    rdf:type owl:Ontology ;
    dcterms:title "City Data Model Part 2 - City Service Pattern - SHACL constraints" ;
    skos:definition "SHACL validation shapes for the City Service Pattern pattern module." ;
    vann:preferredNamespaceUri "https://w3id.org/citydata/part2/v1/" ;
    vann:preferredNamespacePrefix "cdm2" ;
    owl:imports :CityServicePattern ;
    owl:imports :CoreSHACL .

:CatchmentAreaTypeShape
    rdf:type sh:NodeShape ;
    sh:targetClass :CatchmentAreaType ;
    sh:property [
        sh:path :hasCode ;
        sh:class :Code
    ] .

:ImpactDirectionShape
    rdf:type sh:NodeShape ;
    sh:targetClass :ImpactDirection ;
    sh:property [
        sh:path :hasCode ;
        sh:class :Code
    ] .

:ImportanceShape
    rdf:type sh:NodeShape ;
    sh:targetClass :Importance ;
    sh:property [
        sh:path :hasCode ;
        sh:class :Code
    ] .

:InputShape
    rdf:type sh:NodeShape ;
    sh:targetClass :Input ;
    sh:property [
        sh:path cdm1:hasName ;
        sh:node :MaxOneShape ;
        sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path i72:for_time_interval ;
        sh:class time:DateTimeInterval
    ] ;
    sh:property [
        sh:path cdm1:hasDescription ;
        sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path :hasContributingStakeholder ;
        sh:class :Stakeholder
    ] .

:OutcomeShape
    rdf:type sh:NodeShape ;
    sh:targetClass :Outcome ;
    sh:property [
        sh:path :intendedImpact ;
        sh:node :MaxOneShape ;
        sh:class :ImpactDirection
    ] ;
    sh:property [
        sh:path cdm1:hasDescription ;
        sh:node :MaxOneShape ;
        sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path :hasBeneficialStakeholder ;
        sh:node :ExactlyOneShape ;
        sh:class :Stakeholder
    ] ;
    sh:property [
        sh:path :hasImportance ;
        sh:node :MaxOneShape ;
        sh:class :Importance
    ] ;
    sh:property [
        sh:path :fromPerspectiveOf ;
        sh:node :ExactlyOneShape ;
        sh:class :Stakeholder
    ] ;
    sh:property [
        sh:path :hasIndicator ;
        sh:class i72:Indicator
    ] .

:OutputShape
    rdf:type sh:NodeShape ;
    sh:targetClass :Output ;
    sh:property [
        sh:path :usedByIndicator ;
        sh:class i72:Indicator
    ] ;
    sh:property [
        sh:path cdm1:hasName ;
        sh:node :MaxOneShape ;
        sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path cdm1:hasDescription ;
        sh:datatype xsd:string
    ] .

:ProgramShape
    rdf:type sh:NodeShape ;
    sh:targetClass :Program ;
    sh:property [
        sh:path cdm1:hasName ;
        sh:node :MaxOneShape ;
        sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path :hasOutput ;
        sh:class :Output
    ] ;
    sh:property [
        sh:path :hasBeneficialStakeholder ;
        sh:class :Stakeholder
    ] ;
    sh:property [
        sh:path :hasContributingStakeholder ;
        sh:class :Stakeholder
    ] ;
    sh:property [
        sh:path :hasService ;
        sh:class :Service
    ] ;
    sh:property [
        sh:path :hasOutcome ;
        sh:class :Outcome
    ] ;
    sh:property [
        sh:path cdm1:hasDescription ;
        sh:node :MaxOneShape ;
        sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path :hasInput ;
        sh:class :Input
    ] .

:ServiceShape
    rdf:type sh:NodeShape ;
    sh:targetClass :Service ;
    sh:property [
        sh:path cdm1:hasName ;
        sh:node :MaxOneShape ;
        sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path :hasOutput ;
        sh:class :Output
    ] ;
    sh:property [
        sh:path :hasBeneficialStakeholder ;
        sh:class :Stakeholder
    ] ;
    sh:property [
        sh:path :hasContributingStakeholder ;
        sh:class :Stakeholder
    ] ;
    sh:property [
        sh:path :hasInput ;
        sh:class :Input
    ] ;
    sh:property [
        sh:path cdm1:hasDescription ;
        sh:node :MaxOneShape ;
        sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path :hasOutcome ;
        sh:class :Outcome
    ] .

:StakeholderShape
    rdf:type sh:NodeShape ;
    sh:targetClass :Stakeholder ;
    sh:property [
        sh:path :performs ;
        sh:node :MinOneShape ;
        sh:class cdm1:Activity
    ] ;
    sh:property [
        sh:path cdm1:hasDescription ;
        sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path :hasCatchmentArea ;
        sh:class cdm1:Location
    ] ;
    sh:property [
        sh:path :hasCatchmentAreaType ;
        sh:class :CatchmentAreaType
    ] ;
    sh:property [
        sh:path cdm1:hasName ;
        sh:node :MaxOneShape ;
        sh:datatype xsd:string
    ] .
