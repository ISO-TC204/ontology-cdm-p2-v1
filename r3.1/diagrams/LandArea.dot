// Diagram for LandArea
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		cdm1_Location [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm1:Location</TD></TR></TABLE>> URL="https://w3id.org/citydata/part1/v1/Location" margin=0]
		LandUseThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">LandUseThing</TD></TR></TABLE>> URL="../LandUseThing" margin=0]
	}
	LandArea [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">LandArea</TD></TR><TR><TD ALIGN="LEFT">cdm1:hasDescription : xsd:string</TD></TR></TABLE>> URL="../LandArea" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		cdm1_Area [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm1:Area</TD></TR></TABLE>> URL="https://w3id.org/citydata/part1/v1/Area" margin=0]
		i72_Population [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">i72:Population</TD></TR></TABLE>> URL="https://w3id.org/citydata/21972/v1/Population" margin=0]
		LandUseClassification [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">LandUseClassification</TD></TR></TABLE>> URL="../LandUseClassification" margin=0]
	}
	LandArea -> cdm1_Location [arrowhead=onormal style=solid]
	LandArea -> LandUseThing [arrowhead=onormal style=solid]
	LandArea -> Invis [style=invis]
	Invis -> cdm1_Area [style=invis]
	cdm1_Area -> i72_Population [style=invis]
	i72_Population -> LandUseClassification [style=invis]
	LandUseClassification [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">LandUseClassification</TD></TR></TABLE>> URL="../LandUseClassification" margin=0]
	LandArea -> LandUseClassification [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">landUse</TD></TR></TABLE>> arrowhead=normal style=solid]
	cdm1_Area [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm1:Area</TD></TR></TABLE>> URL="https://w3id.org/citydata/part1/v1/Area" margin=0]
	LandArea -> cdm1_Area [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasArea</TD></TR></TABLE>> arrowhead=normal style=solid]
	i72_Population [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">i72:Population</TD></TR></TABLE>> URL="https://w3id.org/citydata/21972/v1/Population" margin=0]
	LandArea -> i72_Population [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasPopulation</TD></TR></TABLE>> arrowhead=normal style=solid]
}
