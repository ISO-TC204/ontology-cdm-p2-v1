// Diagram for Program
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		cdm1_Activity [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm1:Activity</TD></TR></TABLE>> URL="https://w3id.org/citydata/part1/v1/Activity" margin=0]
		CityServiceThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">CityServiceThing</TD></TR></TABLE>> URL="../CityServiceThing" margin=0]
	}
	Program [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Program</TD></TR><TR><TD ALIGN="LEFT">cdm1:hasDescription : xsd:string [0..1]</TD></TR><TR><TD ALIGN="LEFT">cdm1:hasName : xsd:string [0..1]</TD></TR></TABLE>> URL="../Program" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		Input [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Input</TD></TR></TABLE>> URL="../Input" margin=0]
		Outcome [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Outcome</TD></TR></TABLE>> URL="../Outcome" margin=0]
		Output [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Output</TD></TR></TABLE>> URL="../Output" margin=0]
		Service [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Service</TD></TR></TABLE>> URL="../Service" margin=0]
		Stakeholder [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Stakeholder</TD></TR></TABLE>> URL="../Stakeholder" margin=0]
	}
	Program -> cdm1_Activity [arrowhead=onormal style=solid]
	Program -> CityServiceThing [arrowhead=onormal style=solid]
	Program -> Invis [style=invis]
	Invis -> Input [style=invis]
	Input -> Outcome [style=invis]
	Outcome -> Output [style=invis]
	Output -> Service [style=invis]
	Service -> Stakeholder [style=invis]
	Outcome [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Outcome</TD></TR></TABLE>> URL="../Outcome" margin=0]
	Program -> Outcome [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasOutcome</TD></TR></TABLE>> arrowhead=normal style=solid]
	Stakeholder [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Stakeholder</TD></TR></TABLE>> URL="../Stakeholder" margin=0]
	Program -> Stakeholder [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasContributingStakeholder</TD></TR></TABLE>> arrowhead=normal style=solid]
	Service [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Service</TD></TR></TABLE>> URL="../Service" margin=0]
	Program -> Service [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasService</TD></TR></TABLE>> arrowhead=normal style=solid]
	Input [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Input</TD></TR></TABLE>> URL="../Input" margin=0]
	Program -> Input [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasInput</TD></TR></TABLE>> arrowhead=normal style=solid]
	Program -> Stakeholder [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasBeneficialStakeholder</TD></TR></TABLE>> arrowhead=normal style=solid]
	Output [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Output</TD></TR></TABLE>> URL="../Output" margin=0]
	Program -> Output [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasOutput</TD></TR></TABLE>> arrowhead=normal style=solid]
}
