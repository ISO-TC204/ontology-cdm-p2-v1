// Diagram for Input
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		cdm1_TerminalResourceState [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm1:TerminalResourceState</TD></TR></TABLE>> URL="https://w3id.org/citydata/part1/v1/TerminalResourceState" margin=0]
		CityServiceThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">CityServiceThing</TD></TR></TABLE>> URL="../CityServiceThing" margin=0]
	}
	Input [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Input</TD></TR><TR><TD ALIGN="LEFT">cdm1:hasDescription : xsd:string</TD></TR><TR><TD ALIGN="LEFT">cdm1:hasName : xsd:string [0..1]</TD></TR></TABLE>> URL="../Input" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		Stakeholder [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Stakeholder</TD></TR></TABLE>> URL="../Stakeholder" margin=0]
		time_DateTimeInterval [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">time:DateTimeInterval</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/time/latest/DateTimeInterval" margin=0]
	}
	Input -> cdm1_TerminalResourceState [arrowhead=onormal style=solid]
	Input -> CityServiceThing [arrowhead=onormal style=solid]
	Input -> Invis [style=invis]
	Invis -> Stakeholder [style=invis]
	Stakeholder -> time_DateTimeInterval [style=invis]
	Stakeholder [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Stakeholder</TD></TR></TABLE>> URL="../Stakeholder" margin=0]
	Input -> Stakeholder [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">hasContributingStakeholder</TD></TR></TABLE>> arrowhead=normal style=solid]
	time_DateTimeInterval [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">time:DateTimeInterval</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/time/latest/DateTimeInterval" margin=0]
	Input -> time_DateTimeInterval [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">i72:for_time_interval</TD></TR></TABLE>> arrowhead=normal style=solid]
}
