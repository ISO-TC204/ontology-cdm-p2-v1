// Diagram for ContractualCommitment
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		ContractualElement [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ContractualElement</TD></TR></TABLE>> URL="../ContractualElement" margin=0]
	}
	ContractualCommitment [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ContractualCommitment</TD></TR></TABLE>> URL="../ContractualCommitment" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		cdm1_Agreement [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm1:Agreement</TD></TR></TABLE>> URL="https://w3id.org/citydata/part1/v1/Agreement" margin=0]
	}
	ContractualCommitment -> ContractualElement [arrowhead=onormal style=solid]
	ContractualCommitment -> Invis [style=invis]
	Invis -> cdm1_Agreement [style=invis]
	cdm1_Agreement [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">cdm1:Agreement</TD></TR></TABLE>> URL="https://w3id.org/citydata/part1/v1/Agreement" margin=0]
	ContractualCommitment -> cdm1_Agreement [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD ALIGN="CENTER">specifiesAgreement</TD></TR></TABLE>> arrowhead=normal style=solid]
}
