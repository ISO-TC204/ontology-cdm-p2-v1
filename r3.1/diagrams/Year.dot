// Diagram for Year
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		BuildingThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">BuildingThing</TD></TR></TABLE>> URL="../BuildingThing" margin=0]
		time_DateTimeDescription [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">time:DateTimeDescription</TD></TR></TABLE>> URL="https://w3id.org/citydata/imported/time/latest/DateTimeDescription" margin=0]
	}
	Year [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Year</TD></TR></TABLE>> URL="../Year" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
	}
	Year -> BuildingThing [arrowhead=onormal style=solid]
	Year -> time_DateTimeDescription [arrowhead=onormal style=solid]
}
